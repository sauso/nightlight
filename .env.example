# Which host user/group owns files this container creates in the data volume
# (database, logs, MediaMTX config). Defaults to 99/100 - Unraid's own
# "nobody"/"users" convention - so these are usually fine to leave as-is on Unraid.
# On other systems, find your own with: id your_username
PUID=99
PGID=100

# Your local timezone, e.g. Australia/Melbourne - affects log timestamps only.
# Defaults to UTC if unset. Full list:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optional - a random, persistent secret is auto-generated and stored in your data
# volume on first run if this is left blank. Only set this yourself if you
# specifically need a fixed value (e.g. restoring a data volume onto a fresh install
# and want the same secret, though your existing sessions would need to log in again
# either way since the secret only affects newly-issued sessions).
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# Where the app's data (database, logs, MediaMTX config) is stored on the host.
# Defaults to ./data if unset. On Unraid, set this to something like
# /mnt/user/appdata/nightlight so it shows up in the Unraid UI and gets picked up
# by your normal appdata backup routine.
APPDATA_DIR=./data

# Your public IP or (better) a DDNS hostname, only needed for Low Latency (WebRTC)
# mode to work from outside your home network. Leave blank for LAN-only use, or if
# you're fine relying on Compatibility mode remotely. See the README's
# "Remote / internet access" section before setting this.
PUBLIC_HOST=
